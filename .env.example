# .env.example

# Example configuration for SQLite
# Uncomment the following line to use SQLite
# DATABASE_URL=sqlite:///path/to/database.db

# Example configuration for PostgreSQL
# Uncomment the following line to use PostgreSQL
# DATABASE_URL=postgres://username:password@localhost:5432/database_name

# Notes:
# - Replace "path/to/database.db" with the actual path to your SQLite database file.
# - For PostgreSQL, replace "username", "password", "localhost", "5432", and "database_name" with your actual database configuration details.